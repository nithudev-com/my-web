generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                BigInt              @id @default(autoincrement())
  sku               String              @unique
  title             String
  slug              String              @unique
  shortDescription  String?
  description       String?
  status            ProductStatus       @default(ACTIVE)
  basePrice         Decimal             @db.Decimal(12, 2)
  salePrice         Decimal?            @db.Decimal(12, 2)
  stockStatus       StockStatus         @default(IN_STOCK)
  stockQuantity     Int                 @default(0)
  mainImage         String?
  seoTitle          String?
  seoDescription    String?
  canonicalUrl      String?
  categoryId        BigInt?
  brandId           BigInt?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  details           Json?
  faq               Json?
  benefits          Json?
  features          Json?
  focusKeyword      String?
  generatedByAI     Boolean             @default(false)
  ogDescription     String?
  ogTitle           String?
  productType       String?
  readinessScore    Int                 @default(0)
  secondaryKeywords Json?
  specifications    Json?
  tags              Json?
  validationStatus  String?
  videoUrl          String?
  height            Decimal?            @db.Decimal(10, 2)
  isFeatured        Boolean             @default(false)
  length            Decimal?            @db.Decimal(10, 2)
  lowStockLimit     Int?
  returnInfo        String?
  saleEndDate       DateTime?
  saleStartDate     DateTime?
  shippingInfo      Json?
  warrantyInfo      String?
  weight            Decimal?            @db.Decimal(10, 2)
  width             Decimal?            @db.Decimal(10, 2)
  importBatchId     String?
  barcode           String?
  blogs             BlogPost[]          @relation("ProductToBlog")
  brand             Brand?              @relation(fields: [brandId], references: [id])
  category          Category?           @relation(fields: [categoryId], references: [id])
  importBatch       ProductImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  images            ProductImage[]
  variants          ProductVariant[]
  reviews           Review[]
  wishlistedItems   WishlistItem[]

  @@index([status])
  @@index([categoryId, status])
  @@index([brandId, status])
  @@index([updatedAt])
}

model ProductVariant {
  id            BigInt      @id @default(autoincrement())
  productId     BigInt
  sku           String      @unique
  price         Decimal     @db.Decimal(12, 2)
  salePrice     Decimal?    @db.Decimal(12, 2)
  stockQuantity Int         @default(0)
  stockStatus   StockStatus @default(IN_STOCK)
  attributes    Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  image         String?
  isEnabled     Boolean     @default(true)
  barcode       String?
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([price])
  @@index([stockStatus])
}

model Category {
  id             BigInt     @id @default(autoincrement())
  name           String
  slug           String     @unique
  parentId       BigInt?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  image          String?
  showOnHome     Boolean    @default(false)
  sortOrder      Int        @default(0)
  parent         Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryTree")
  products       Product[]

  @@index([parentId])
}

model Brand {
  id             BigInt    @id @default(autoincrement())
  name           String
  slug           String    @unique
  logo           String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  showOnHome     Boolean   @default(true)
  faqs           Json?
  products       Product[]
}

model ProductImage {
  id        BigInt  @id @default(autoincrement())
  productId BigInt
  imageUrl  String
  altText   String?
  sortOrder Int     @default(0)
  bytes     Int?
  format    String?
  height    Int?
  isPrimary Boolean @default(false)
  publicId  String?
  width     Int?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Review {
  id        BigInt   @id @default(autoincrement())
  productId BigInt
  rating    Int
  title     String?
  body      String?
  author    String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, approved])
}

model ProductImportBatch {
  id          String             @id
  filename    String?
  status      ImportStatus       @default(PENDING)
  totalRows   Int                @default(0)
  successRows Int                @default(0)
  failedRows  Int                @default(0)
  message     String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  updateMode  String             @default("FULL")
  products    Product[]
  rows        ProductImportRow[]
}

model ProductImportRow {
  id             BigInt             @id @default(autoincrement())
  batchId        String
  rowNumber      Int
  sku            String?
  title          String?
  slug           String?
  categorySlug   String?
  categoryName   String?
  brandSlug      String?
  brandName      String?
  price          Decimal?           @db.Decimal(12, 2)
  salePrice      Decimal?           @db.Decimal(12, 2)
  stockQuantity  Int?
  imageUrl       String?
  seoTitle       String?
  seoDescription String?
  rawData        Json?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime           @default(now())
  barcode        String?
  variantImage   String?
  batch          ProductImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([batchId, errorMessage])
  @@index([sku])
}

model Currency {
  id           BigInt   @id @default(autoincrement())
  code         String   @unique
  name         String
  symbol       String
  exchangeRate Decimal  @default(1.0000) @db.Decimal(10, 4)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                   BigInt                @id @default(autoincrement())
  email                String                @unique
  passwordHash         String
  firstName            String?
  lastName             String?
  orders               Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  acceptTerms          Boolean               @default(false)
  marketingConsent     Boolean               @default(false)
  phone                String?
  ageConfirmed         Boolean               @default(false)
  isBlocked            Boolean               @default(false)
  contactConversations ContactConversation[]
  addresses            CustomerAddress[]
  emailJobs            EmailJob[]
  emailPreferences     EmailPreference?
  wishlist             Wishlist?
  notifications        Notification[]
  sessions             CustomerSession[]

  @@index([email])
}

model CustomerSession {
  id            String    @id @default(cuid())
  tokenHash     String    @unique
  customerId    BigInt
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  lastUsedAt    DateTime  @default(now())
  ipHash        String?
  userAgentHash String?
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tokenHash])
}

model CustomerAddress {
  id                BigInt   @id @default(autoincrement())
  customerId        BigInt
  firstName         String
  lastName          String
  company           String?
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  postalCode        String
  country           String
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model ShippingMethod {
  id            BigInt   @id @default(autoincrement())
  name          String
  price         Decimal  @db.Decimal(12, 2)
  estimatedDays String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Coupon {
  id            BigInt    @id @default(autoincrement())
  code          String    @unique
  discountType  String
  discountValue Decimal   @db.Decimal(12, 2)
  minOrderValue Decimal?  @db.Decimal(12, 2)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  usageLimit    Int?
  usageCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
}

model PaymentGateway {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique
  merchantId String?
  publicKey  String?
  secretKey  String?
  isActive   Boolean  @default(false)
  isTestMode Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

model Order {
  id              BigInt      @id @default(autoincrement())
  orderNumber     String      @unique
  customerId      BigInt?
  customerEmail   String
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("CAD")
  status          OrderStatus @default(PENDING)
  paymentRef      String?     @unique
  shippingAddress Json?
  billingAddress  Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  secureToken     String      @unique @default(cuid())
  items           OrderItem[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id         BigInt  @id @default(autoincrement())
  orderId    BigInt
  productId  BigInt
  variantId  BigInt?
  title      String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Wishlist {
  id         BigInt         @id @default(autoincrement())
  customerId BigInt         @unique
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]
}

model WishlistItem {
  id         BigInt   @id @default(autoincrement())
  wishlistId BigInt
  productId  BigInt
  variantId  BigInt?
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId, variantId])
  @@index([wishlistId])
}

model ContactConversation {
  id               BigInt           @id @default(autoincrement())
  conversationId   String           @unique @default(cuid())
  customerId       BigInt?
  guestName        String?
  guestEmail       String?
  guestPhone       String?
  guestToken       String?          @unique
  category         String
  orderId          String?
  subject          String
  status           ContactStatus    @default(NEW)
  priority         ContactPriority  @default(NORMAL)
  assignedAdminId  BigInt?
  source           String           @default("WEB_FORM")
  isReadByAdmin    Boolean          @default(false)
  isReadByCustomer Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastReplyAt      DateTime?
  closedAt         DateTime?
  customer         Customer?        @relation(fields: [customerId], references: [id])
  messages         ContactMessage[]

  @@index([customerId])
  @@index([guestEmail])
  @@index([status])
  @@index([guestToken])
}

model ContactMessage {
  id               BigInt              @id @default(autoincrement())
  conversationId   BigInt
  senderType       String
  senderCustomerId BigInt?
  senderAdminId    BigInt?
  body             String
  attachment       String?
  createdAt        DateTime            @default(now())
  readAt           DateTime?
  conversation     ContactConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model StoreSettings {
  id                  Int      @id @default(1)
  storeName           String   @default("SpeedCommerce")
  storeDescription    String   @default("Your premium destination for the world's best products. Fast shipping, secure payments, and 24/7 support.")
  facebookUrl         String?
  twitterUrl          String?
  instagramUrl        String?
  updatedAt           DateTime @updatedAt
  taxEnabled          Boolean  @default(false)
  taxIncludedInPrices Boolean  @default(false)
  taxRate             Decimal  @default(0.0000) @db.Decimal(5, 4)
}

model BlogPost {
  id                 BigInt   @id @default(autoincrement())
  title              String
  slug               String   @unique
  excerpt            String?
  content            String
  coverImage         String?
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  aiGenerationStatus String?
  aiModel            String?
  faqs               Json?
  focusKeyword       String?
  generatedByAI      Boolean  @default(false)
  secondaryKeywords  Json?
  seoDescription     String?
  seoScore           Int      @default(0)
  seoTitle           String?
  sourceProductId    BigInt?
  sourceProduct      Product? @relation("ProductToBlog", fields: [sourceProductId], references: [id])

  @@index([slug])
  @@index([isPublished])
  @@index([sourceProductId])
}

model EmailPreference {
  id                BigInt   @id @default(autoincrement())
  customerId        BigInt   @unique
  topics            Json?
  globalUnsubscribe Boolean  @default(false)
  isBounced         Boolean  @default(false)
  isSpamComplaint   Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        BigInt       @id @default(autoincrement())
  name      String       @unique
  subject   String
  htmlBody  String
  textBody  String?
  channel   EmailChannel @default(TRANSACTIONAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  jobs      EmailJob[]
}

model EmailCampaign {
  id          BigInt      @id @default(autoincrement())
  name        String
  subject     String
  status      EmailStatus @default(PENDING)
  scheduledAt DateTime?
  sentCount   Int         @default(0)
  failedCount Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  jobs        EmailJob[]
}

model EmailJob {
  id             BigInt         @id @default(autoincrement())
  idempotencyKey String         @unique
  channel        EmailChannel   @default(TRANSACTIONAL)
  status         EmailStatus    @default(PENDING)
  recipientEmail String
  customerId     BigInt?
  templateId     BigInt?
  campaignId     BigInt?
  payload        Json?
  attemptCount   Int            @default(0)
  maxAttempts    Int            @default(3)
  nextAttemptAt  DateTime?
  providerMsgId  String?
  errorLogs      Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sentAt         DateTime?
  campaign       EmailCampaign? @relation(fields: [campaignId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id])
  template       EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([status, nextAttemptAt])
  @@index([idempotencyKey])
  @@index([recipientEmail])
}

model CategoryCircle {
  id        BigInt   @id @default(autoincrement())
  name      String
  image     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  BACKORDER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
  DELIVERED
}

enum ContactStatus {
  NEW
  OPEN
  AWAITING_CUSTOMER
  AWAITING_ADMIN
  RESOLVED
  CLOSED
  SPAM
}

enum ContactPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum EmailChannel {
  TRANSACTIONAL
  MARKETING
  AUTOMATION
  ADMIN
}

enum EmailStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model Notification {
  id         BigInt   @id @default(autoincrement())
  customerId BigInt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  message    String
  read       Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId, read])
}

model AdminUser {
  id           BigInt         @id @default(autoincrement())
  email        String         @unique
  passwordHash String
  name         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id            String    @id @default(cuid())
  tokenHash     String    @unique
  adminId       BigInt
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  lastUsedAt    DateTime  @default(now())
  ipHash        String?
  userAgentHash String?
  admin         AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([tokenHash])
}

model GoogleMerchantConnection {
  id                      BigInt    @id @default(autoincrement())
  merchantAccountId       String    @unique
  merchantAccountName     String?
  googleUserEmail         String?
  encryptedRefreshToken   String?
  grantedScopes           String?
  status                  String    @default("PENDING")
  apiVersion              String    @default("v1")
  connectedByAdminId      BigInt?
  connectedAt             DateTime  @default(now())
  lastSuccessfulRequestAt DateTime?
  lastFailedRequestAt     DateTime?
  disconnectedAt          DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  dataSources        GoogleMerchantDataSource[]
  configurations     GoogleProductConfiguration[]
  statuses           GoogleProductStatus[]
  issues             GoogleMerchantIssue[]
  syncJobs           GoogleMerchantSyncJob[]
  mappings           GoogleMerchantMapping[]
  rules              GoogleMerchantRule[]
  reportSnapshots    GoogleMerchantReportSnapshot[]
  notificationEvents GoogleMerchantNotificationEvent[]
  auditLogs          GoogleMerchantAuditLog[]

  @@index([merchantAccountId])
}

model GoogleMerchantDataSource {
  id                 BigInt                   @id @default(autoincrement())
  connectionId       BigInt
  googleResourceName String?                  @unique
  displayName        String
  sourceType         String
  feedLabel          String?
  language           String?
  countries          String?
  inputMethod        String?
  status             String                   @default("PENDING")
  lastUploadAt       DateTime?
  lastProcessedAt    DateTime?
  rawMetadata        Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  connection         GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
}

model GoogleProductConfiguration {
  id                       BigInt                   @id @default(autoincrement())
  productId                BigInt                   @unique
  connectionId             BigInt
  enabled                  Boolean                  @default(false)
  offerId                  String?                  @unique
  targetCountry            String?
  contentLanguage          String?
  feedLabel                String?
  condition                String?
  googleProductCategory    String?
  productType              String?
  titleOverride            String?
  descriptionOverride      String?
  imageOverride            String?
  customLabels             Json?
  excludedMarketingMethods Json?
  includedMarketingMethods Json?
  lastSubmittedAt          DateTime?
  lastProcessedAt          DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  connection               GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([productId])
  @@index([offerId])
}

model GoogleProductStatus {
  id                    BigInt                   @id @default(autoincrement())
  productId             BigInt                   @unique
  connectionId          BigInt
  offerId               String?
  productInputName      String?
  processedProductName  String?
  approvalState         String?
  processingState       String?
  reportingContexts     Json?
  processedPrice        Decimal?                 @db.Decimal(12, 2)
  processedAvailability String?
  expirationDate        DateTime?
  issueCount            Int                      @default(0)
  lastFetchedAt         DateTime?
  rawSnapshot           Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  connection            GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([productId])
  @@index([offerId])
  @@index([approvalState])
}

model GoogleMerchantIssue {
  id               BigInt                   @id @default(autoincrement())
  connectionId     BigInt
  productId        BigInt?
  googleIssueCode  String
  issueType        String
  severity         String
  title            String
  description      String?
  country          String?
  reportingContext String?
  documentationUrl String?
  firstDetectedAt  DateTime?
  lastDetectedAt   DateTime?
  deadline         DateTime?
  status           String                   @default("ACTIVE")
  rawPayload       Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  connection       GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([productId])
  @@index([severity])
  @@index([status])
}

model GoogleMerchantSyncJob {
  id                 BigInt                   @id @default(autoincrement())
  connectionId       BigInt
  jobType            String
  scope              String?
  status             String                   @default("QUEUED")
  totalItems         Int                      @default(0)
  processedItems     Int                      @default(0)
  successItems       Int                      @default(0)
  warningItems       Int                      @default(0)
  failedItems        Int                      @default(0)
  requestedByAdminId BigInt?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  errorSummary       String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  connection         GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  items              GoogleMerchantSyncItem[]

  @@index([connectionId])
  @@index([status])
}

model GoogleMerchantSyncItem {
  id              BigInt                @id @default(autoincrement())
  syncJobId       BigInt
  productId       BigInt?
  offerId         String?
  operation       String
  status          String                @default("PENDING")
  attemptCount    Int                   @default(0)
  googleRequestId String?
  errorCode       String?
  errorMessage    String?
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  syncJob         GoogleMerchantSyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId])
  @@index([productId])
  @@index([status])
}

model GoogleMerchantMapping {
  id             BigInt                   @id @default(autoincrement())
  connectionId   BigInt
  googleField    String
  sourceType     String
  sourceValue    String?
  fallbackValue  String?
  transformation String?
  priority       Int                      @default(0)
  active         Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  connection     GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([googleField])
}

model GoogleMerchantRule {
  id               BigInt                   @id @default(autoincrement())
  connectionId     BigInt
  name             String
  priority         Int                      @default(0)
  conditions       Json?
  actions          Json?
  active           Boolean                  @default(true)
  createdByAdminId BigInt?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  connection       GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([active])
}

model GoogleMerchantReportSnapshot {
  id           BigInt                   @id @default(autoincrement())
  connectionId BigInt
  reportType   String
  reportDate   DateTime
  dimensions   Json?
  metrics      Json?
  createdAt    DateTime                 @default(now())
  connection   GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([reportType])
  @@index([reportDate])
}

model GoogleMerchantNotificationEvent {
  id               BigInt                   @id @default(autoincrement())
  connectionId     BigInt
  subscriptionName String?
  eventType        String
  eventHash        String                   @unique
  status           String                   @default("PENDING")
  receivedAt       DateTime                 @default(now())
  processedAt      DateTime?
  errorMessage     String?
  rawPayload       Json?
  connection       GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([eventHash])
  @@index([status])
}

model GoogleMerchantAuditLog {
  id           BigInt                   @id @default(autoincrement())
  connectionId BigInt
  adminId      BigInt?
  action       String
  resourceType String?
  resourceId   String?
  beforeData   Json?
  afterData    Json?
  status       String                   @default("SUCCESS")
  requestId    String?
  createdAt    DateTime                 @default(now())
  connection   GoogleMerchantConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([action])
  @@index([resourceType])
}
