#!/usr/bin/expect -f
set timeout -1
set password [lindex $argv 0]
set src [lindex $argv 1]
set dest [lindex $argv 2]

spawn rsync -avz -e "ssh -o StrictHostKeyChecking=no -p 65002" $src u549656247@82.29.157.55:$dest
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    eof
}
